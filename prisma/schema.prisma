generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["driverAdapters"]
}

datasource db {
  provider = "postgresql"
}

enum UserRole {
  customer
  driver
  admin
}

enum DriverStatus {
  online
  offline
  busy
}

enum OrderStatus {
  PENDING
  CONFIRMED
  DRIVER_OTW
  DRIVER_ARRIVED
  IN_PROGRESS
  COMPLETED
  CANCELLED
}

enum PaymentMethod {
  cash
  qris
}

enum PaymentStatus {
  pending
  confirmed
  failed
}

model User {
  id           String    @id @default(uuid())
  name         String
  phone        String    @unique
  email        String?   @unique
  passwordHash String
  role         UserRole  @default(customer)
  photoUrl     String?
  pushToken    String?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  driver           Driver?
  ordersAsCustomer Order[]  @relation("CustomerOrders")
  reviewsGiven     Review[] @relation("CustomerReviews")
}

model Driver {
  id           String       @id @default(uuid())
  userId       String       @unique
  user         User         @relation(fields: [userId], references: [id])
  vehicleName  String
  vehiclePlate String       @unique
  status       DriverStatus @default(offline)
  lat          Float?
  lng          Float?
  rating       Float        @default(0)
  totalTrips   Int          @default(0)
  qrisImageUrl String?
  createdAt    DateTime     @default(now())
  updatedAt    DateTime     @updatedAt

  orders  Order[]  @relation("DriverOrders")
  reviews Review[] @relation("DriverReviews")
}

model Package {
  id            String   @id @default(uuid())
  name          String
  price         Float
  durationHours Int
  destinations  Json
  isActive      Boolean  @default(true)
  maxPax        Int      @default(6)
  centerLat     Float?
  centerLng     Float?
  radiusKm      Float?
  description   String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  orders Order[]
}

model Order {
  id            String        @id @default(uuid())
  orderCode     String        @unique
  customerId    String
  customer      User          @relation("CustomerOrders", fields: [customerId], references: [id])
  driverId      String?
  driver        Driver?       @relation("DriverOrders", fields: [driverId], references: [id])
  packageId     String
  package       Package       @relation(fields: [packageId], references: [id])
  status        OrderStatus   @default(PENDING)
  pickupLat     Float
  pickupLng     Float
  pickupAddress String
  scheduledAt   DateTime
  totalPrice    Float
  pax           Int           @default(1)
  paymentMethod PaymentMethod
  paymentStatus PaymentStatus @default(pending)
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  payment Payment?
  review  Review?
}

model Payment {
  id          String        @id @default(uuid())
  orderId     String        @unique
  order       Order         @relation(fields: [orderId], references: [id])
  method      PaymentMethod
  amount      Float
  status      PaymentStatus @default(pending)
  confirmedBy String?
  confirmedAt DateTime?
  proofUrl    String?
  createdAt   DateTime      @default(now())
}

model Review {
  id         String   @id @default(uuid())
  orderId    String   @unique
  order      Order    @relation(fields: [orderId], references: [id])
  customerId String
  customer   User     @relation("CustomerReviews", fields: [customerId], references: [id])
  driverId   String
  driver     Driver   @relation("DriverReviews", fields: [driverId], references: [id])
  rating     Int
  comment    String?
  createdAt  DateTime @default(now())
}
